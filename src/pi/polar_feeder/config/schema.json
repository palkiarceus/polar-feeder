{
  "type": "object",
  "properties": {
    "stillness": {
      "type": "object",
      "properties": {
        "publish_hz": { "type": "number", "minimum": 1, "maximum": 30 },
        "trigger_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "min_duration_s": { "type": "number", "minimum": 0, "maximum": 60 }
      },
      "required": ["publish_hz", "trigger_threshold", "min_duration_s"]
    },
    "logging": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "telemetry_hz": { "type": "number", "minimum": 1, "maximum": 30 },
        "max_storage_mb": { "type": "number", "minimum": 10, "maximum": 5000 },
        "log_dir": { "type": "string" }
      },
      "required": ["enabled", "telemetry_hz", "max_storage_mb", "log_dir"]
    },
    "radar": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": "string" },
        "baud": { "type": "integer", "minimum": 1200, "maximum": 2000000 },
        "timeout_s": { "type": "number", "minimum": 0.0, "maximum": 5.0 },
        "zone_m": {
          "type": "array",
          "items": { "type": "number", "minimum": 0.1, "maximum": 50 },
          "minItems": 1
        },
        "distance_jump_m": { "type": "number", "minimum": 0.01, "maximum": 5.0 },
        "detection_distance_m": { "type": "number", "minimum": 0.5, "maximum": 50.0 }
      },
      "required": ["enabled", "port", "baud", "timeout_s", "zone_m", "distance_jump_m", "detection_distance_m"]
    },
    "safety": {
      "type": "object",
      "properties": {
        "ble_disconnect_safe_idle": { "type": "boolean" }
      },
      "required": ["ble_disconnect_safe_idle"]
    "actuator": {
      "type": "object",
      "properties": {
        "retract_delay_ms": { "type": "integer", "minimum": 0, "maximum": 3000 },
        "pulse_ms": { "type": "integer", "minimum": 50, "maximum": 1000 },
        "feeding_distance_m": { "type": "number", "minimum": 0.1, "maximum": 5.0 }
      },
      "required": ["retract_delay_ms", "pulse_ms", "feeding_distance_m"]
    },
    "vision": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "motion_threshold": { "type": "number", "minimum": 0.0, "maximum": 1000.0 },
        "sync_window_s": { "type": "number", "minimum": 0.1, "maximum": 5.0 }
      },
      "required": ["enabled", "motion_threshold", "sync_window_s"]
    }
  },
  "required": ["stillness", "logging", "radar", "safety", "actuator", "vision"]
}
