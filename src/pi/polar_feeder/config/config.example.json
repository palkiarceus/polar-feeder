{
  "stillness": {
    "publish_hz": 5,
    "trigger_threshold": 0.85,
    "min_duration_s": 2.0
  },
  "logging": {
    "enabled": true,
    "telemetry_hz": 5,
    "max_storage_mb": 500,
    "log_dir": "logs"
  },
  "radar": {
    "enabled": false,
    "port": "/dev/ttyAMA0",
    "baud": 115200,
    "timeout_s": 0.1,
    "zone_m": [1.0, 2.0, 3.0]
  },
  "safety": {
    "ble_disconnect_safe_idle": true
  },
  "actuator": {
    "retract_delay_ms": 2500,
    "pulse_ms": 200
  }

}
